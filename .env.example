# Optional. With a key set, the in-app concierge streams live answers from Groq.
# Without it, the app falls back to a built-in heuristic guide so the demo always works.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional override for the chat model. Defaults to llama-3.3-70b-versatile.
TRIP_COPILOT_MODEL=llama-3.3-70b-versatile
